{
  "version": 1,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "crabswarm hook exec --ft go 'golangci-lint fmt {{.File}}'",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
