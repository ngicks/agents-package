{
  "version": 1,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Multiedit",
        "hooks": [
          {
            "type": "command",
            "command": "crabswarm hook exec --ft go 'goimports -w {{.File}}'",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
