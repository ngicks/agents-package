{
  "version": 1,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Multiedit",
        "hooks": [
          {
            "type": "command",
            "command": "./run.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./run.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
