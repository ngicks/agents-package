{
  "version": 1,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "crabswarm hook exec --ft go 'golangci-lint run {{dirname .File}}'",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
