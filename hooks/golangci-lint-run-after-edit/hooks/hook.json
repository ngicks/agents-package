{
  "version": 1,
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "crabswarm hook exec --ft go 'golangci-lint run {{dirname .File}}'",
            "timeoutSec": 300
          }
        ]
      }
    ]
  }
}
